# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=intel_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=threat_intel
DATABASE_URL=postgresql://intel_admin:change_me_strong_password@db:5432/threat_intel

# ─── AI Engine ────────────────────────────────────────────────────────────────
# Ollama (local, free): install from https://ollama.com then run: ollama pull llama3.2
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Cloud AI fallbacks — get free keys at:
#   Claude:  https://console.anthropic.com/
#   Gemini:  https://aistudio.google.com/
CLAUDE_API_KEY=
GEMINI_API_KEY=

# ─── OSINT API Keys (all free tiers) ──────────────────────────────────────────
