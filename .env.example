# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=intel_admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=threat_intel
DATABASE_URL=postgresql://intel_admin:change_me_strong_password@db:5432/threat_intel

# ─── AI Engine ────────────────────────────────────────────────────────────────
# Ollama (local, free): install from https://ollama.com then run: ollama pull llama3.2
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Cloud AI fallbacks — get free keys at:
#   Claude:  https://console.anthropic.com/
#   Gemini:  https://aistudio.google.com/
CLAUDE_API_KEY=
GEMINI_API_KEY=

# ─── Web UI ───────────────────────────────────────────────────────────────────
# install.sh sets this automatically to the first free port at or above 8501
WEBUI_PORT=8501

# ─── OSINT API Keys (all free tiers) ──────────────────────────────────────────
# Abuse.ch (single key covers ThreatFox, URLhaus, MalwareBazaar)
#   Register free at: https://auth.abuse.ch/
ABUSECH_API_KEY=

# AlienVault OTX: https://otx.alienvault.com/api
OTX_API_KEY=

# ─── Dark Web Monitor ─────────────────────────────────────────────────────────
# Set to true to enable dark web monitoring (requires Tor proxy container).
# Monitors publicly accessible dark web indexes — metadata ONLY, no breach content.
DARK_WEB_ENABLED=false

# Comma-separated keywords to watch (your org's domains, brands, IPs).
# Example: acme.com,acmecorp,192.168.1.0/24
DARK_WEB_KEYWORDS=

# (Optional) Comma-separated publicly accessible .onion index/search URLs to monitor.
# Only include no-login-required public index pages.
DARK_WEB_ONION_SOURCES=

# How often to scan (seconds). Default 21600 = 6 hours.
DARK_WEB_INTERVAL=21600

# ─── REST API ─────────────────────────────────────────────────────────────────
# Port for the FastAPI REST API + TAXII 2.1 server
API_PORT=8000

# ─── IOC Enrichment APIs ──────────────────────────────────────────────────────
# VirusTotal: https://www.virustotal.com/gui/my-apikey (free tier: 4 req/min)
VT_API_KEY=

# GreyNoise Community: https://www.greynoise.io/ (free community key)
GREYNOISE_API_KEY=

# Shodan: https://account.shodan.io/ (free account: limited)
SHODAN_API_KEY=

# GitHub: https://github.com/settings/tokens (needs repo:read scope)
GITHUB_TOKEN=

# ─── Alerting ─────────────────────────────────────────────────────────────────
# Configure alert channels in the Admin tab — no env vars needed.
# SMTP details can also go here as fallback:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=
